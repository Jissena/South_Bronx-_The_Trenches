local isDrag,dOX,dOY=false,0,0
UIS.InputBegan:Connect(function(i)
	if i.UserInputType~=Enum.UserInputType.MouseButton1 then return end
	local mx,my=i.Position.X,i.Position.Y
	local fp,fs=mf.AbsolutePosition,mf.AbsoluteSize
	if mx<fp.X or mx>fp.X+fs.X or my<fp.Y or my>fp.Y+fs.Y then return end
	-- Jangan drag saat menyentuh tombol/input/slider
	if isSliding then return end
	for _,obj in ipairs(mf:GetDescendants()) do
		if (obj:IsA("TextButton") or obj:IsA("TextBox")) and obj.Visible then
			local op,os=obj.AbsolutePosition,obj.AbsoluteSize
			if mx>=op.X and mx<=op.X+os.X and my>=op.Y and my<=op.Y+os.Y then return end
		end
	end
	-- Cek area track/slider
	local tp,ts=track.AbsolutePosition,track.AbsoluteSize
	if mx>=tp.X-10 and mx<=tp.X+ts.X+10 and my>=tp.Y-10 and my<=tp.Y+ts.Y+10 then return end
	isDrag=true; dOX=mx-fp.X; dOY=my-fp.Y
end)
UIS.InputEnded:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.MouseButton1 then isDrag=false end
end)
RunService.Heartbeat:Connect(function()
	if not isDrag then return end
	local m=UIS:GetMouseLocation()
	mf.Position=UDim2.fromOffset(m.X-dOX,m.Y-dOY)
end)

