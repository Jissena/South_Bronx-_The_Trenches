-- Fungsi update slider
local function updateSlider(ratio)
	ratio=math.clamp(ratio,0,1)
	jumlahBeli=math.floor(ratio*(SLIDER_MAX-SLIDER_MIN)+0.5)
	local pct=(jumlahBeli-SLIDER_MIN)/(SLIDER_MAX-SLIDER_MIN)
	fill.Size=UDim2.new(pct,0,1,0)
	knob.Position=UDim2.new(pct,-9,0.5,-9)
	jumlahLbl.Text=jumlahBeli.."/"..SLIDER_MAX
end
updateSlider(0)

-- Slider input event-based
local isSliding=false
